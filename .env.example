# ============================================================
# hermes_bedrock_agent - Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- AWS ---
AWS_REGION=ap-northeast-1

# --- Bedrock Knowledge Bases ---
# Multi-KB (preferred): comma-separated "label:id" pairs
BEDROCK_KNOWLEDGE_BASES=docs:XXXXXXXXXX,sales:YYYYYYYYYY,support:ZZZZZZZZZZ

# Legacy single-KB (used if BEDROCK_KNOWLEDGE_BASES not set)
# BEDROCK_KNOWLEDGE_BASE_ID=XXXXXXXXXX
# BEDROCK_KNOWLEDGE_BASE_LABEL=my-kb

# --- S3 Source ---
S3_BUCKET=s3-hulftchina-rd
S3_PREFIX=output/

# --- Neptune Analytics ---
NEPTUNE_ENDPOINT=
NEPTUNE_GRAPH_ID=

# --- Embedding ---
EMBEDDING_PROVIDER=bedrock
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSION=1024

# --- Vision LLM (for scanned PDFs, images, diagrams) ---
VISION_LLM_PROVIDER=bedrock
VISION_LLM_MODEL_ID=anthropic.claude-sonnet-4-20250514

# --- Text LLM (for entity/relation extraction) ---
TEXT_LLM_PROVIDER=bedrock
TEXT_LLM_MODEL_ID=anthropic.claude-sonnet-4-20250514

# --- Run Mode ---
DRY_RUN=true

# --- Legacy (GraphRAG experiment) ---
# GRAPHRAG_DB_PATH=~/.hermes_bedrock_agent/graphrag.db
# GRAPHRAG_S3_BUCKET=s3-hulftchina-rd
# GRAPHRAG_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
# NEPTUNE_ANALYTICS_GRAPH_ID=
