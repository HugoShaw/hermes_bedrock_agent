# ============================================================
# hermes_bedrock_agent - Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- AWS ---
AWS_REGION=ap-northeast-1

# --- Bedrock Knowledge Bases ---
# Multi-KB (preferred): comma-separated "label:id" pairs
BEDROCK_KNOWLEDGE_BASES=docs:XXXXXXXXXX,sales:YYYYYYYYYY,support:ZZZZZZZZZZ

# Legacy single-KB (used if BEDROCK_KNOWLEDGE_BASES not set)
# BEDROCK_KNOWLEDGE_BASE_ID=XXXXXXXXXX
# BEDROCK_KNOWLEDGE_BASE_LABEL=my-kb

# --- S3 Source ---
S3_BUCKET=s3-hulftchina-rd
S3_PREFIX=output/

# --- Neptune Analytics ---
NEPTUNE_ENDPOINT=
NEPTUNE_GRAPH_ID=
# Legacy alias (fallback if NEPTUNE_GRAPH_ID not set)
# NEPTUNE_ANALYTICS_GRAPH_ID=

# --- OpenSearch (text/vector retrieval) ---
OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX_NAME=enterprise-graphrag
OPENSEARCH_REGION=ap-northeast-1
OPENSEARCH_USE_SERVERLESS=true
OPENSEARCH_USE_SSL=true
OPENSEARCH_AWS_SIGV4=true
OPENSEARCH_VECTOR_FIELD=embedding
OPENSEARCH_TEXT_FIELD=text

# --- Embedding ---
EMBEDDING_PROVIDER=bedrock
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=25

# --- Vision LLM (for scanned PDFs, images, diagrams) ---
VISION_LLM_PROVIDER=bedrock
VISION_LLM_MODEL_ID=anthropic.claude-sonnet-4-20250514

# --- Text LLM (for entity/relation extraction, answer generation) ---
TEXT_LLM_PROVIDER=bedrock
TEXT_LLM_MODEL_ID=anthropic.claude-sonnet-4-20250514

# --- Ingestion ---
INGESTION_MAX_FILE_SIZE_MB=50
INGESTION_ENABLE_INCREMENTAL=true

# --- Chunking ---
CHUNKING_MAX_TOKENS=512
CHUNKING_OVERLAP_TOKENS=64
CHUNKING_STRATEGY=fixed

# --- Graph Extraction ---
GRAPH_EXTRACTION_MODEL_ID=anthropic.claude-sonnet-4-20250514
GRAPH_NORMALIZE_ENTITIES=true
GRAPH_QUALITY_REVIEW=true
GRAPH_MIN_CONFIDENCE=0.7

# --- Retrieval ---
RETRIEVAL_TEXT_TOP_K=10
RETRIEVAL_GRAPH_TOP_K=5
RETRIEVAL_FUSION_STRATEGY=rrf
RETRIEVAL_RRF_K=60

# --- Vector Store ---
# Backend: 'lancedb' (local, default) or 'opensearch' (remote)
VECTOR_STORE_BACKEND=lancedb
VECTOR_DISTANCE=cosine
VECTOR_TOP_K=10
# LanceDB local settings (only used when VECTOR_STORE_BACKEND=lancedb)
VECTOR_LOCAL_STORE_PATH=/home/ubuntu/projects/data/vector_store/lancedb
VECTOR_LOCAL_COLLECTION=murata_e2e
VECTOR_RRF_K=60

# --- Enrichment (Optional Stage — disabled by default) ---
# Enrichment adds multilingual display names and business aliases.
# The default pipeline works without it. Enable explicitly when needed.
ENRICHMENT_ENABLED=false
ENRICHMENT_MODE=none
ENRICHMENT_MAX_ENTITIES=200
ENRICHMENT_UPDATE_NEPTUNE=false

# --- Application ---
LOG_LEVEL=INFO
DRY_RUN=true

# --- Legacy (GraphRAG experiment) ---
# GRAPHRAG_DB_PATH=~/.hermes_bedrock_agent/graphrag.db
# GRAPHRAG_S3_BUCKET=s3-hulftchina-rd
# GRAPHRAG_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
