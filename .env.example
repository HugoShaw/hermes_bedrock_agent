# ============================================================
# DualRAG .env.example — v0.3.0
# Copy to .env and customize for your environment.
# ============================================================

# --- AWS / Bedrock ---
AWS_REGION=ap-northeast-1

# Text / chat model (inference profile prefix required in ap-northeast-1)
BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-6
BEDROCK_TEXT_MODEL_ID=jp.anthropic.claude-sonnet-4-6

# VLM model for document image parsing
BEDROCK_VLM_MODEL_ID=jp.anthropic.claude-sonnet-4-6
BEDROCK_VLM_FALLBACK_MODEL_ID=mistral.mistral-large-3-675b-instruct
VISION_LLM_MODEL_ID=jp.anthropic.claude-sonnet-4-6

# Embedding model
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- S3 ---
S3_BUCKET=your-s3-bucket-name

# --- LanceDB (Vector Store) ---
VECTOR_STORE_BACKEND=lancedb
VECTOR_LOCAL_STORE_PATH=/home/ubuntu/projects/data/vector_store/lancedb
VECTOR_LOCAL_COLLECTION=murata_e2e_murata_full_vlm_live_001

# --- Neptune (Graph Store) ---
NEPTUNE_ENDPOINT=your-neptune-endpoint.ap-northeast-1.neptune-graph.amazonaws.com
NEPTUNE_GRAPH_ID=your-graph-id
NEPTUNE_DATASET=murata

# --- Bedrock Knowledge Bases (optional, for KB query mode) ---
# Format: alias:kb_id,alias:kb_id,...
BEDROCK_KNOWLEDGE_BASES=alias1:KB_ID_1,alias2:KB_ID_2
BEDROCK_KNOWLEDGE_BASE_ID=YOUR_KB_ID

# --- Chunking ---
CHUNK_MODE=semantic
CHUNK_SEMANTIC_MAX_CHARS=4000
CHUNK_SEMANTIC_GROUP_TARGET=2000
# Enable type-aware chunking strategies (MermaidFlowchartStrategy, etc.)
# CHUNK_STRATEGY_ENABLED=false

# --- Reranking (optional, post-retrieval) ---
# Enable to use Bedrock rerank model after hybrid retrieval
RERANK_ENABLED=false
# Model: amazon.rerank-v1:0 (available), cohere.rerank-v3-5:0 (requires Marketplace sub)
RERANK_MODEL_ID=amazon.rerank-v1:0
# Number of hybrid candidates sent to reranker
RERANK_CANDIDATE_K=30
# Final top-K after reranking
RERANK_TOP_K=5
# Fall back to hybrid ordering on rerank API error (recommended: true)
RERANK_FALLBACK_ON_ERROR=true
# Rerank API timeout in seconds
RERANK_TIMEOUT_SECONDS=30

# --- Logging ---
LOG_LEVEL=INFO
