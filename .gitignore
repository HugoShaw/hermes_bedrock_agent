# ============================================================
# hermes_bedrock_agent - .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.so

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- uv ---
.uv/
uv.lock

# --- Environment / Secrets / Keys ---
# NEVER commit secrets, API keys, credentials, or auth tokens
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.jks
*.p12
*.pfx
iam_*.json
*credentials*
*secret*
*token*

# --- AWS / Cloud Infrastructure IDs ---
# Files containing AWS account numbers, Neptune Graph IDs, or resource ARNs
iam_neptune_data_policy.json
NEPTUNE_FIX_GUIDE.md

# --- Configs (may contain endpoints, IDs, credentials) ---
configs/

# --- Logs ---
*.log
logs/

# --- Data (input files, source Excel/PDF, vector stores, caches) ---
data/
tmp/
cache/
/tmp/

# --- Output / Generated artifacts (screenshots, PDFs, parsed results) ---
# These are large generated artifacts; regenerate from source
outputs/
output/

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# --- Agent context files (local-only, never commit) ---
.hermes.md
.claude_*.md

# --- Archive (old code, kept locally for reference but NOT tracked in git) ---
# Contains legacy scripts with hardcoded AWS account IDs, Neptune graph IDs,
# security group IDs, and other sensitive infrastructure identifiers.
# These files are preserved on disk for reference but MUST NOT be committed.
archive/

